{
  "name": "@omgoods/contracts",
  "private": true,
  "scripts": {
    "start": "hardhat node",
    "linter": "solhint \"contracts/**/*.sol\"",
    "format": "prettier --write \"{contracts,deploy,scripts,src,test}/**/*.{ts,sol}\"",
    "compile": "hardhat compile",
    "test": "hardhat test",
    "coverage": "SOLIDITY_COVERAGE=1 hardhat coverage",
    "deploy": "hardhat deploy",
    "deployments:export": "hardhat deployments:export",
    "deployments:verify": "hardhat deployments:verify",
    "tokens:generate": "hardhat --network localhost tokens:generate",
    "hardhat": "hardhat"
  },
  "dependencies": {
    "@openzeppelin/contracts": "5.1.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ledger": "1.0.3",
    "@nomicfoundation/hardhat-toolbox": "5.0.0",
    "@types/fs-extra": "11.0.4",
    "@typescript-eslint/eslint-plugin": "6.21.0",
    "@typescript-eslint/parser": "6.21.0",
    "dotenv-pre": "0.0.3",
    "eslint": "8.57.1",
    "eslint-config-prettier": "9.1.0",
    "eslint-config-standard": "17.1.0",
    "eslint-plugin-chai-friendly": "1.0.1",
    "eslint-plugin-node": "11.1.0",
    "fs-extra": "11.2.0",
    "hardhat": "2.22.13",
    "hardhat-deploy": "0.14.0",
    "hardhat-gas-reporter": "2.2.1",
    "prettier": "3.3.3",
    "prettier-plugin-solidity": "1.4.1",
    "solhint": "5.0.3",
    "solidity-coverage": "0.8.13"
  }
}
