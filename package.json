{
  "name": "@omgoods/contracts",
  "private": true,
  "scripts": {
    "start": "hardhat node",
    "linter": "solhint \"contracts/**/*.sol\"",
    "format": "prettier --write \"{contracts,deploy,scripts,src,test}/**/*.{ts,sol}\"",
    "compile": "hardhat compile",
    "test": "hardhat test",
    "coverage": "hardhat coverage",
    "deploy": "hardhat deploy",
    "deployments:export": "hardhat deployments:export",
    "deployments:verify": "hardhat deployments:verify",
    "tokens:create": "hardhat run scripts/tokens/create/run.ts",
    "tokens:seed": "hardhat --network localhost run ./scripts/tokens/seed/run.ts",
    "hardhat": "hardhat"
  },
  "dependencies": {
    "@openzeppelin/contracts": "5.0.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ledger": "1.0.1",
    "@nomicfoundation/hardhat-toolbox": "3.0.0",
    "@types/fs-extra": "11.0.2",
    "@types/prompts": "2.4.6",
    "@typescript-eslint/eslint-plugin": "6.7.5",
    "@typescript-eslint/parser": "6.7.5",
    "dotenv-pre": "0.0.3",
    "eslint": "8.51.0",
    "eslint-config-prettier": "9.0.0",
    "eslint-config-standard": "17.1.0",
    "eslint-plugin-chai-friendly": "0.7.2",
    "eslint-plugin-node": "11.1.0",
    "fs-extra": "11.1.1",
    "hardhat": "2.18.0",
    "hardhat-deploy": "0.11.42",
    "prettier": "3.0.3",
    "prettier-plugin-solidity": "1.1.3",
    "prompts": "2.4.2",
    "solhint": "3.6.2"
  }
}
